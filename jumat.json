    },
    "pelajar_jumat_npc_5A2": {
        "speakerType": "right",
        "speakerName": "Pak Diding",
        "charRight": "assets/images/char/pakdiding.png",
        "time": "15:00",
        "text": "Nguawor, belum tepat! Kedepannya kalian harus lebih sadar tentang topik ini.",
        "next": "pelajar_jumat_npc_5A3"
